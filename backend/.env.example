## Backend runtime
NODE_ENV=development
PORT=5000

## Storage switch
# Set to "postgres" to use PostgreSQL instead of CSV files.
DATA_STORE=csv

## PostgreSQL (DigitalOcean / managed Postgres)
# IMPORTANT: Do NOT commit real secrets. Put real values in a local `.env`
# or VM environment variables (PM2/Nginx/systemd).
PGHOST=soliflex-db-do-user-xxxxxxxxx-0.a.db.ondigitalocean.com
PGPORT=25060
PGDATABASE=defaultdb
PGUSER=doadmin
PGPASSWORD=__SET_ME__

# DigitalOcean managed Postgres typically requires TLS.
# For `pg`, we enable SSL when `PGSSLMODE=require`.
PGSSLMODE=require
